name: Twitch Live Check

on:
  schedule:
    - cron: "*/5 * * * *"  # every 5 minutes
  workflow_dispatch:

jobs:
  check:
    runs-on: ubuntu-latest

    steps:
      - name: Check streams
        run: |
          streamers=("iblamejosephh" "ManicPan" "boldylocks91" "diamondbat_" "BigBadDude83" "helanamatta" "mochabeautyxo_")

          for streamer in "${streamers[@]}"
          do
            status=$(curl -s https://decapi.me/twitch/uptime/$streamer)

            if [[ $status != *"offline"* ]]; then
              curl -H "Content-Type: application/json" \
              -X POST \
              -d "{
  \"embeds\": [
    {
      \"title\": \"🔴 $streamer is LIVE\",
      \"description\": \"Click to watch now: https://twitch.tv/$streamer\",
      \"url\": \"https://twitch.tv/$streamer\",
      \"color\": 16711680,
      \"thumbnail\": {
        \"url\": \"https://static-cdn.jtvnw.net/previews-ttv/live_user_${streamer}-320x180.jpg\"
      },
      \"footer\": {
        \"text\": \"Twitch Live Alerts\"
      }
    }
  ]
}"
 \
              https://discord.com/api/webhooks/1497062577304506394/g1vutyNJ4_rrydRh5YTLBZlhsqu7gnhzMh-DqLJC03A4yUKVhM8Enkc6Jy1qJ-NMiWcE
            fi
          done
